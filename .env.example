# PlannerXchange development environment
# Copy this file to .env and adjust values.

# API mode: "mock" for local development, "live" when running inside PX shell
VITE_PX_MODE=mock

# PX API base URL (only used when VITE_PX_MODE=live)
# Leave blank for local dev — the gateway stub returns mock data.
VITE_PX_API_BASE=
